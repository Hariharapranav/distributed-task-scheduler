# ─────────────────────────────────────────────
#  Distributed Task Scheduler – Environment Config
# ─────────────────────────────────────────────

# App
APP_ENV=development
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=taskscheduler
POSTGRES_USER=taskuser
POSTGRES_PASSWORD=taskpassword
DATABASE_URL=postgresql+asyncpg://taskuser:taskpassword@postgres:5432/taskscheduler
SYNC_DATABASE_URL=postgresql://taskuser:taskpassword@postgres:5432/taskscheduler

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_TASK_EVENTS=task.events
KAFKA_TOPIC_NOTIFICATIONS=notifications
KAFKA_TOPIC_AUDIT=audit_log
KAFKA_GROUP_ID=notification-consumer-group

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@taskscheduler.com
SMTP_TLS=true

# Webhook
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_MAX_RETRIES=3

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# Frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
